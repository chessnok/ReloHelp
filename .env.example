# Copy to .env and fill in. Consumed by docker compose for variable
# interpolation. Per-service runtime config lives in backend/.env.

# Shared secret between backend <-> mcp (X-Internal-Token).
INTERNAL_API_TOKEN=changeme-internal-token

# --- RAG (mcp service, pgvector) ---
RAG_ENABLED=true
RAG_TABLE=rag_threads
RAG_EMBED_WORKERS=8

# Optional: override RAG storage DB (defaults to compose `db` service).
# RAG_DATABASE_URL=postgresql://postgres:postgres@db:5432/postgres

# Firecrawl (find_official_info tool). Get at https://firecrawl.dev
# FIRECRAWL_API_KEY=fc-...

# Ollama runs on the docker host (not in compose). The mcp service maps
# host.docker.internal -> host-gateway via extra_hosts.
# Linux host:
#   curl -fsSL https://ollama.com/install.sh | sh
#   ollama serve
#   ollama pull mxbai-embed-large
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_EMBED_MODEL=mxbai-embed-large
